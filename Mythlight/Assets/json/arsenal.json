    { "id": 5, "name": "Cleave", "description": "Succesful attacks with this weapon inflict 1 compromised, once per turn." },
    { "id": 6, "name": "Parry", "description": "As a reaction, you may parry an attack that would strike you. You must roll [Reflex] vs the attack roll to succeed. A parried attack has no effect."},
    { "id": 7, "name": "Lunge", "description": "You may dash 1 tile when you take the Attack action with this weapon. (This movement can be used to get into position for a melee attack.)" },
    { "id": 8, "name": "Reach", "description": "This weapon can be used to make melee attacks against targets within 2 tiles." },
    { "id": 9, "name": "Block", "description": "As a reaction, you may block an attack that would strike you. Doing so reduces the damage taken by 1." },
    { "id": 10, "name": "Hook", "description": "You may attempt to pull a target within 2 tiles 1 tile closer to you, they must roll [Reflex] vs [6+ your Might] to resist." },
    { "id": 11, "name": "Charge", "description": "You may dash 2 tiles when you take the Attack action with this weapon. (This movement can be used to get into position for a melee attack.)" },
    { "id": 12, "name": "Versatile", "description": "You may weild this weapon with one or both hands. If weilded with 1 hand only, it has -1 Accuracy." },
    { "id": 13, "name": "Brutal", "description": "You may expend an extra action to deal +2 damage with this weapon." },
    { "id": 14, "name": "Sweep", "description": "You may make a sweeping attack that hits all enemies in a 2 tile cone. They must roll [Reflex] vs the attack roll to resist." },
    { "id": 15, "name": "Crush", "description": "Succesful attacks with this weapon inflict 2 compromised, once per turn." }
